# PostgreSQL (docker-compose service: postgres)
POSTGRES_USER=ticket_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tickets_db

# Backend — use host "postgres" inside Docker; localhost:5432 when using docker-compose postgres on host
DATABASE_URL=postgresql://ticket_user:changeme@localhost:5432/tickets_db

# JWT (placeholder only — replace in local .env, never commit real values)
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Frontend — browser calls backend on host port
VITE_API_URL=http://localhost:8000
